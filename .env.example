# ════════════════════════════════════════════════════════════
# BlockAds Filter Compiler API — Environment Configuration
# ════════════════════════════════════════════════════════════

# Server
PORT=8080
ENVIRONMENT=development   # "development" or "production"
ADMIN_TOKEN=your_secret_admin_token   # required for DELETE endpoints

# PostgreSQL
DATABASE_URL=postgres://blockads:blockads@localhost:5432/blockads?sslmode=disable

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=blockads-filters
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
